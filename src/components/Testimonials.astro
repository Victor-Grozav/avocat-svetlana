---
const testimonials = [
  {
    text: '„Datorită profesionalismului și dedicării doamnei avocat Grozav, am reușit să rezolv un litigiu imobiliar complex care dura de trei ani. Abordarea calmă și strategia bine gândită au făcut toată diferența. Recomand cu toată încrederea."',
    name: 'M.P.',
    location: 'Chișinău',
  },
  {
    text: '„Consiliere clară, onestă și la obiect. Am apreciat în mod deosebit faptul că am fost informat la fiecare pas al procesului, fără surprize neplăcute. Un avocat în care poți avea cu adevărat încredere."',
    name: 'A.C.',
    location: 'Bălți',
  },
  {
    text: '„Doamna avocat Grozav m-a ajutat să navighez un proces de succesiune extrem de complicat. Profesionalism desăvârșit, empatie și rezultate concrete. Sunt extrem de recunoscătoare."',
    name: 'E.M.',
    location: 'Chișinău',
  },
  {
    text: '„Am apelat la serviciile dnei Grozav pentru un litigiu contractual. A gestionat totul cu maximă competență și discreție. Cazul s-a rezolvat amiabil, exact cum speram."',
    name: 'V.T.',
    location: 'Cahul',
  },
];
---

<section id="testimoniale" style="padding: 8rem 0; position: relative; overflow: hidden; background: var(--navy-950);">
  <!-- Decorative background quote -->
  <div style="position: absolute; top: -2rem; left: -1rem; font-family: var(--font-serif); font-size: 25rem; color: var(--gold-400); opacity: 0.015; line-height: 1; pointer-events: none; user-select: none;" aria-hidden="true">"</div>

  <div class="container">
    <div class="testimonials-header animate-fade-up">
      <span class="section-label" style="justify-content: center; display: flex;">Clienți mulțumiți</span>
      <h2 class="section-title" style="text-align: center;">Ce spun <em>clienții</em></h2>
    </div>

    <div class="testimonials-grid">
      {testimonials.map((t, i) => (
        <div class="testimonial-card animate-fade-up" style={`--index: ${i};`}>
          <div class="testimonial-stars">
            {Array.from({length: 5}).map(() => (
              <div class="star"></div>
            ))}
          </div>
          <p class="testimonial-text">{t.text}</p>
          <div class="testimonial-author">
            <span class="author-name">{t.name}</span>
            <span class="author-location">— client, {t.location}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .testimonial-card {
    background: var(--navy-800);
    padding: 2.5rem;
    border-left: 2px solid var(--gold-400);
    position: relative;
  }

  .testimonial-stars {
    display: flex;
    gap: 3px;
    margin-bottom: 1.25rem;
  }

  .star {
    width: 14px;
    height: 14px;
    background: var(--gold-400);
    clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
  }

  .testimonial-text {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.05rem;
    font-weight: 300;
    color: var(--cream-200);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
  }

  .testimonial-author::before {
    content: '';
    display: block;
    width: 20px;
    height: 1px;
    background: var(--gold-400);
    flex-shrink: 0;
  }

  .author-name {
    font-weight: 500;
    color: var(--cream-100);
    letter-spacing: 0.05em;
  }

  .author-location {
    color: var(--slate-400);
  }

  @media (max-width: 768px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
