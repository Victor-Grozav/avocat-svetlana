---
const steps = [
  {
    number: '1',
    title: 'Consultație Inițială',
    desc: 'Discutăm situația dvs. juridică și stabilim împreună obiectivele de urmat.',
  },
  {
    number: '2',
    title: 'Analiză a Cazului',
    desc: 'Studiem documentele, evaluăm temeiul juridic și identificăm toate opțiunile disponibile.',
  },
  {
    number: '3',
    title: 'Strategie Juridică',
    desc: 'Elaborăm planul de acțiune optim, adaptat specificului cazului dvs.',
  },
  {
    number: '4',
    title: 'Reprezentare & Soluție',
    desc: 'Acționăm în numele dvs. cu determinare și obținem rezultatul dorit.',
  },
];
---

<section id="proces" style="padding: 8rem 0; background: var(--navy-900);">
  <div class="container">
    <div class="process-header animate-fade-up">
      <span class="section-label" style="justify-content: center; display: flex;">Cum lucrez</span>
      <h2 class="section-title" style="text-align: center;">Procesul <em>meu</em></h2>
    </div>

    <div class="process-steps">
      {steps.map((step, i) => (
        <div class="process-step animate-fade-up" style={`--index: ${i};`}>
          <div class="step-circle">
            <span class="step-number">{step.number}</span>
          </div>
          <h3 class="step-title">{step.title}</h3>
          <p class="step-desc">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    position: relative;
  }

  .process-steps::before {
    content: '';
    position: absolute;
    top: 22px;
    left: calc(12.5%);
    right: calc(12.5%);
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-200), var(--gold-200), transparent);
    opacity: 0.2;
  }

  .process-step {
    text-align: center;
    padding: 0 1.5rem;
  }

  .step-circle {
    width: 44px;
    height: 44px;
    border: 1px solid var(--gold-400);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    background: var(--navy-900);
    position: relative;
    z-index: 1;
  }

  .step-number {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--gold-400);
    line-height: 1;
  }

  .step-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--cream-100);
    margin-bottom: 0.75rem;
  }

  .step-desc {
    font-size: 0.8rem;
    color: var(--slate-400);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .process-steps {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }

    .process-steps::before {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .process-steps {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
