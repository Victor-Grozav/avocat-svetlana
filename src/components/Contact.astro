---

<section id="contact" style="padding: 8rem 0; background: var(--navy-900);">
  <div class="container">
    <div class="contact-header animate-fade-up">
      <span class="section-label" style="justify-content: center; display: flex;">Luați legătura</span>
      <h2 class="section-title" style="text-align: center;">Contactați-mă <em>astăzi</em></h2>
    </div>

    <div class="contact-layout">

      <!-- Contact Info -->
      <div class="animate-fade-up">
        <h3 class="contact-info-title">Sunt disponibilă pentru a vă asculta și a găsi împreună soluția potrivită.</h3>

        <div class="contact-items">
          <div class="contact-item">
            <div class="contact-item-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.8a16 16 0 0 0 6.29 6.29l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div class="contact-item-text">
              <span class="contact-item-label">Telefon</span>
              <div class="contact-item-value">
                <a href="tel:+37369039821">+373 69 039 821</a>
              </div>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-item-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div class="contact-item-text">
              <span class="contact-item-label">Email</span>
              <div class="contact-item-value">
                <a href="mailto:grozav23@mail.ru">grozav23@mail.ru</a>
              </div>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-item-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div class="contact-item-text">
              <span class="contact-item-label">Adresă</span>
              <div class="contact-item-value">mun. Chișinău, Republica Moldova</div>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-item-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="contact-item-text">
              <span class="contact-item-label">Program</span>
              <div class="contact-item-value">Luni – Vineri: 09:00 – 18:00</div>
            </div>
          </div>
        </div>

        <div class="contact-social">
          <a href="https://wa.me/37369039821" class="social-btn" aria-label="WhatsApp" target="_blank" rel="noopener">
            <!-- WhatsApp brand icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
          <a href="https://t.me/+37369039821" class="social-btn" aria-label="Telegram" target="_blank" rel="noopener">
            <!-- Telegram brand icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          </a>
          <a href="viber://chat?number=%2B37369039821" class="social-btn" aria-label="Viber">
            <!-- Viber brand icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M11.398.002C9.473.028 5.331.344 3.014 2.467 1.294 4.177.693 6.698.623 9.82c-.07 3.12-.154 8.972 5.5 10.594h.005l-.005 2.432s-.038.959.6 1.152c.77.236 1.217-.49 1.95-1.275.402-.433.957-1.067 1.373-1.556 3.784.317 6.691-.408 7.023-.515.763-.245 5.081-.796 5.781-6.498.72-5.876-.35-9.585-2.843-11.252-.745-.498-3.737-1.924-8.61-1.9zm.105 1.55c4.22-.026 6.989 1.175 7.588 1.572 2.09 1.394 3.02 4.728 2.39 9.943-.598 4.88-4.081 5.186-4.718 5.392-.273.088-2.889.733-6.19.52 0 0-2.453 2.953-3.219 3.721-.12.12-.259.17-.352.147-.13-.033-.166-.188-.164-.414l.02-3.617c-4.812-1.337-4.545-6.318-4.489-8.972.06-2.652.553-4.81 2.003-6.233 1.978-1.818 5.614-2.086 7.131-2.06zm.2 3.063c-.228.001-.392.01-.458.02a.698.698 0 0 0 .12 1.389c.044-.005.244-.015.46-.015 1.994 0 3.066 1.077 3.066 3.026 0 .216-.01.413-.016.456a.697.697 0 0 0 .636.755.7.7 0 0 0 .756-.634c.008-.077.02-.346.02-.577 0-2.777-1.597-4.42-4.583-4.42zm-2.697.626a.702.702 0 0 0-.695.64c-.01.104-.006.21.015.316.022.107.348 1.71.93 2.55.35.505.718.862 1.06 1.12.093.07.174.124.245.166.072.044.135.08.19.108.109.057.2.085.274.094.036.004.07.004.104.002a.698.698 0 0 0 .647-.745.7.7 0 0 0-.506-.635c-.027-.01-.066-.027-.113-.052-.07-.039-.178-.113-.307-.232-.237-.218-.506-.554-.743-.898-.42-.607-.7-1.97-.724-2.083a.7.7 0 0 0-.377-.351zm3.044.997c-.363.006-.66.294-.677.66-.02.378.27.7.649.717.786.037 1.163.44 1.19 1.27.013.378.33.672.71.659a.693.693 0 0 0 .658-.71c-.046-1.417-.833-2.554-2.53-2.596zm-3.785 4.08c-.26.007-.498.141-.638.36-.14.218-.16.49-.053.726.58 1.29 1.58 2.177 3.07 2.712a.7.7 0 0 0 .896-.43.7.7 0 0 0-.43-.896c-1.144-.41-1.864-1.046-2.293-2.013a.698.698 0 0 0-.552-.459z"/></svg>
          </a>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="animate-fade-up" style="--index: 1;">
        <form
          class="contact-form"
          id="contact-form"
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p style="display: none;"><label>Don't fill this out: <input name="bot-field" /></label></p>

          <h3 class="form-title">Trimiteți o solicitare</h3>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="name">Nume complet *</label>
              <input type="text" id="name" name="name" class="form-input" placeholder="Ion Popescu" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="phone">Telefon *</label>
              <input type="tel" id="phone" name="phone" class="form-input" placeholder="+373 XX XXX XXX" required />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="email">Email</label>
            <input type="email" id="email" name="email" class="form-input" placeholder="email@exemplu.md" />
          </div>

          <div class="form-group">
            <label class="form-label" for="subject">Domeniu de interes *</label>
            <select id="subject" name="subject" class="form-select" required>
              <option value="">Selectați domeniul...</option>
              <option value="litigii">Litigii Civile</option>
              <option value="proprietate">Dreptul Proprietății</option>
              <option value="succesiuni">Succesiuni și Moșteniri</option>
              <option value="contracte">Contracte Civile</option>
              <option value="familie">Dreptul Familiei</option>
              <option value="consultanta">Consultanță Juridică</option>
              <option value="altele">Altele</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="message">Descrieți situația dvs. *</label>
            <textarea id="message" name="message" class="form-textarea" placeholder="Descrieți pe scurt situația juridică pentru care aveți nevoie de asistență..." required></textarea>
          </div>

          <button type="submit" class="btn-submit" id="submit-btn">
            Trimiteți Solicitarea
          </button>
        </form>
      </div>

    </div>
  </div>
</section>

<style>
  .contact-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 5rem;
    align-items: start;
  }

  .contact-info-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--cream-100);
    margin-bottom: 2.5rem;
    line-height: 1.3;
  }

  .contact-items {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .contact-item-icon {
    width: 36px;
    height: 36px;
    border: 1px solid rgba(201, 168, 76, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold-400);
    flex-shrink: 0;
  }

  .contact-item-text {
    padding-top: 0.35rem;
  }

  .contact-item-label {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--slate-500);
    display: block;
    margin-bottom: 0.2rem;
  }

  .contact-item-value {
    font-size: 0.95rem;
    color: var(--cream-200);
  }

  .contact-item-value a {
    transition: color 0.3s ease;
  }

  .contact-item-value a:hover {
    color: var(--gold-400);
  }

  .contact-social {
    display: flex;
    gap: 0.75rem;
  }

  .social-btn {
    width: 40px;
    height: 40px;
    border: 1px solid rgba(201, 168, 76, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--slate-400);
    transition: border-color 0.3s ease, color 0.3s ease;
  }

  .social-btn:hover {
    border-color: var(--gold-400);
    color: var(--gold-400);
  }

  .contact-form {
    background: var(--navy-800);
    padding: 3rem;
    border: 1px solid rgba(201, 168, 76, 0.08);
  }

  .form-title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--cream-100);
    margin-bottom: 2rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(201, 168, 76, 0.1);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--slate-400);
    margin-bottom: 0.5rem;
  }

  .form-input,
  .form-select,
  .form-textarea {
    width: 100%;
    background: var(--navy-900);
    border: 1px solid rgba(201, 168, 76, 0.1);
    color: var(--cream-100);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 300;
    padding: 0.75rem 1rem;
    outline: none;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    appearance: none;
  }

  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    border-color: var(--gold-400);
    box-shadow: 0 0 0 3px var(--gold-glow);
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: var(--slate-500);
  }

  .form-select option {
    background: var(--navy-800);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .btn-submit {
    width: 100%;
    background: transparent;
    border: 1px solid var(--gold-400);
    color: var(--gold-400);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 1rem;
    cursor: pointer;
    transition: background 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;
    margin-top: 0.5rem;
  }

  .btn-submit:hover {
    background: var(--gold-400);
    color: var(--navy-950);
    box-shadow: 0 0 30px var(--gold-glow);
  }

  @media (max-width: 900px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .contact-form {
      padding: 2rem 1.5rem;
    }
  }
</style>
