---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    title: 'Litigii Civile',
    shortDesc: 'Reprezentare profesionistă în toate fazele procesuale.',
    fullDesc: [
      'Reprezentare profesionistă în instanță în cauze civile la toate nivelurile judiciare — judecătorie, curte de apel și Curtea Supremă de Justiție din Republica Moldova.',
      'Serviciile includ: pregătirea și depunerea cererilor de chemare în judecată, formularea apelurilor și recursurilor, reprezentarea în ședințele de judecată, negocieri prelitigioase și mediere.',
      'Abordez fiecare litigiu cu o analiză riguroasă a dosarului și o strategie adaptată specificului cauzei, urmărind obținerea celui mai bun rezultat posibil pentru client.',
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12M12 12L7 7M12 12L17 7M3 12h4M17 12h4M12 2v4"/><circle cx="12" cy="22" r="1"/></svg>`,
  },
  {
    title: 'Dreptul Proprietății',
    shortDesc: 'Tranzacții imobiliare, litigii de vecinătate, uzucapiune.',
    fullDesc: [
      'Asistență juridică completă în materia dreptului proprietății imobiliare: tranzacții de vânzare-cumpărare, donații, schimburi de bunuri imobile, verificarea legalității titlurilor de proprietate.',
      'Serviciile acoperă: litigii de vecinătate și granițe, uzucapiune (dobândirea proprietății prin posesie îndelungată), partaj judiciar și extrajudiciar al bunurilor imobile, acțiuni în revendicare.',
      'Reprezint clienții în fața instanțelor de judecată, a notarilor și a autorităților cadastrale, asigurând apărarea drepturilor de proprietate în conformitate cu legislația moldovenească în vigoare.',
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
  {
    title: 'Succesiuni și Moșteniri',
    shortDesc: 'Asistență completă în proceduri succesorale.',
    fullDesc: [
      'Proceduri succesorale complexe: acceptarea sau renunțarea la moștenire, eliberarea certificatelor de moștenitor, partajul voluntar sau judiciar al masei succesorale.',
      'Asistență în: contestarea testamentelor (nulitate, anulare), acțiuni în reducțiunea liberalităților excesive, stabilirea cotelor succesorale, soluționarea conflictelor între moștenitori.',
      'Ofer consiliere clară și empatică în momente dificile, asigurând respectarea drepturilor legitime ale fiecărui moștenitor și finalizarea eficientă a procedurilor.',
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>`,
  },
  {
    title: 'Contracte Civile',
    shortDesc: 'Redactare, analiză, negociere contracte.',
    fullDesc: [
      'Redactarea și revizuirea contractelor civile: contracte de vânzare-cumpărare, locațiune, comodat, împrumut, prestări servicii, antrepriză și alte tipuri de contracte reglementate de Codul Civil al Republicii Moldova.',
      'Analiză juridică riguroasă înainte de semnare: identificarea clauzelor dezavantajoase, a riscurilor juridice și a lacunelor care ar putea genera litigii ulterioare.',
      'Rezolvarea disputelor contractuale: negociere, mediere, arbitraj sau reprezentare în instanță. Asistență în executarea obligațiilor contractuale și recuperarea prejudiciilor.',
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  },
  {
    title: 'Dreptul Familiei',
    shortDesc: 'Divorț, partaj bunuri, custodie copii.',
    fullDesc: [
      'Asistență juridică în toate procedurile de dreptul familiei: divorț amiabil sau contencios, partajul bunurilor comune dobândite în timpul căsătoriei.',
      'Cauze privind copiii: stabilirea domiciliului copilului minor după divorț, reglementarea programului de vizite, modificarea sau contestarea hotărârilor anterioare, pensie alimentară (stabilire, modificare, executare).',
      'Abordare echilibrată și centrată pe soluții amiabile acolo unde este posibil, cu prioritizarea interesului superior al copilului și minimizarea traumei pentru toți membrii familiei.',
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    title: 'Consultanță Juridică',
    shortDesc: 'Consiliere preventivă, avize juridice, due diligence.',
    fullDesc: [
      'Consultanță juridică punctuală sau continuă pentru persoane fizice: analiză situații juridice complexe, opinie juridică scrisă, asistență în relația cu instituțiile statului.',
      'Servicii pentru persoane juridice: due diligence contractual, avize juridice privind conformitatea cu legislația în vigoare, consultanță în structurarea tranzacțiilor.',
      'Consultația inițială vă permite să înțelegeți clar drepturile și opțiunile disponibile, să evaluați riscurile juridice și să luați decizii informate — prevenind astfel litigii costisitoare.',
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    title: 'Legislație Cadastrală',
    shortDesc: 'Înregistrări imobiliare, titluri de proprietate, agenții cadastrale.',
    fullDesc: [
      'Asistență juridică completă în procedurile de înregistrare a bunurilor imobile la Agenția pentru Relații Funciare și Cadastru: dobândirea și încetarea dreptului de proprietate, verificarea legalității titlurilor, obținerea documentației cadastrale necesare.',
      'Reprezentare în litigii imobiliare complexe: uzucapiune (dobândirea proprietății prin posesie îndelungată), accesiunea imobilelor, confirmarea și revendicarea drepturilor de proprietate, contestarea actelor cadastrale nelegale.',
      'Consultanță și redactare pentru tranzacții imobiliare: contracte de vânzare-cumpărare, donații, schimburi de bunuri, asistență în negociere — cu scopul obținerii dreptului real dorit în cel mai scurt timp posibil, în conformitate cu Codul Civil al Republicii Moldova.',
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg>`,
  },
  {
    title: 'Litigii de Muncă',
    shortDesc: 'Protecția drepturilor angajaților, concedieri, recuperare salarii.',
    fullDesc: [
      'Reprezentare completă în litigiile de muncă, de partea angajatului: analiza contractului individual de muncă, negocieri directe cu angajatorul, contestarea sancțiunilor disciplinare aplicate nelegal, contestarea concedierii abuzive și reintegrarea în funcție, în conformitate cu Codul Muncii al Republicii Moldova.',
      'Asistență în recuperarea drepturilor bănești: salariile neachitate, indemnizațiile de concediere, despăgubirile pentru daune materiale și morale suferite ca urmare a încălcării legislației muncii. Urmărirea răspunderii administrative și penale a angajatorilor care nesocotesc drepturile salariaților.',
      'Consultanță în toate fazele raportului de muncă: încheierea, modificarea și încetarea contractelor individuale de muncă, clauze de neconcurență și confidențialitate, regimul juridic al concediilor, protecția muncii și securitatea în câmpul muncii.',
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>`,
  },
  {
    title: 'Contestare Proces Verbal Contravențional',
    shortDesc: 'Anularea amenzilor, suspendarea permisului, apărare în instanță.',
    fullDesc: [
      'Reprezentare completă în contestarea proceselor verbale contravenționale întocmite de poliție, inspecții sau alte autorități competente. Analizez legalitatea actului contravențional, viciile de procedură și împrejurările care exclud sau atenuează răspunderea — asigurând apărarea drepturilor dvs. din prima etapă.',
      'Asistență în toate tipurile de contravenții: circulație rutieră (inclusiv suspendarea dreptului de conducere), contravenții fiscale, contravenții la regimul vamal, sancțiuni aplicate de Inspecția Muncii sau alte organe de control. Contestarea se face în conformitate cu Codul Contravențional al Republicii Moldova.',
      'Procedura de contestare: depunerea plângerii în termenul legal, reprezentarea în ședințele de judecată, formularea apelului dacă este necesar. O abordare strategică și o cunoaștere profundă a legislației contravenționale pot duce la anularea sancțiunii sau reducerea semnificativă a acesteia.',
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
  },
  {
    title: 'Drept Administrativ',
    shortDesc: 'Contestarea actelor administrative, contencios administrativ.',
    fullDesc: [
      'Asistență și reprezentare în litigii de contencios administrativ: contestarea actelor administrative emise de autoritățile publice centrale și locale, anularea deciziilor ilegale sau nejustificate, apărarea drepturilor persoanelor vătămate prin acte administrative — în conformitate cu Codul Administrativ al Republicii Moldova.',
      'Servicii specializate: contestarea deciziilor autorităților fiscale și de control, asistență în proceduri privind achizițiile publice și concesiunile, contestarea refuzurilor nejustificate de eliberare a autorizațiilor sau avizelor, acces la informații de interes public.',
      'Reprezentarea persoanelor fizice și juridice în fața instanțelor de contencios administrativ, a Curții de Apel și a Curții Supreme de Justiție. Redactarea petițiilor, contestațiilor și recursurilor administrative, cu o abordare riguroasă bazată pe jurisprudența instanțelor moldovenești.',
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><path d="M9 21v-4a3 3 0 0 1 6 0v4"/></svg>`,
  },
];
---

<BaseLayout
  title="Servicii Juridice | Avocat Grozav Svetlana — Republica Moldova"
  description="Servicii juridice complete de drept civil: litigii civile, dreptul proprietății, succesiuni, contracte, dreptul familiei, consultanță juridică în Republica Moldova."
>
  <Header />
  <main>

    <!-- Page Hero -->
    <section class="servicii-hero">
      <div class="servicii-hero-bg">
        <img src="/images/tribunal.jpg" alt="Tribunal Republica Moldova" class="servicii-hero-img" />
        <div class="servicii-hero-overlay"></div>
      </div>
      <div class="container servicii-hero-content">
        <div style="max-width: 700px; position: relative; z-index: 2;">
          <span class="section-label">Domenii de practică</span>
          <h1 class="section-title">Servicii juridice<br><em>specializate</em></h1>
          <p style="color: var(--slate-400); font-size: 1rem; line-height: 1.85; margin-top: 1.5rem; max-width: 560px;">
            Ofer reprezentare juridică și consiliere specializată în toate domeniile dreptului civil din Republica Moldova. Fiecare caz beneficiază de atenție personalizată și o strategie juridică riguroasă.
          </p>
          <div style="margin-top: 2.5rem; display: flex; gap: 1.5rem; flex-wrap: wrap;">
            <a href="/#contact" class="btn-primary">Consultație gratuită</a>
            <a href="/#despre" class="btn-secondary">Despre mine</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Detail -->
    <section style="padding: 6rem 0; background: var(--navy-900);">
      <div class="container">
        <div class="services-detail-grid">
          {services.map((service, i) => (
            <div class="service-detail-card animate-fade-up" style={`--index: ${i};`}>
              <div class="service-detail-header">
                <div class="service-detail-icon" set:html={service.icon} />
                <div>
                  <span style="font-size: 0.65rem; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold-400);">0{i + 1}</span>
                  <h2 class="service-detail-title">{service.title}</h2>
                  <p class="service-detail-short">{service.shortDesc}</p>
                </div>
              </div>
              <div class="service-detail-body">
                {service.fullDesc.map(para => (
                  <p>{para}</p>
                ))}
              </div>
              <a href="/#contact" class="service-detail-cta">
                Solicitați consiliere
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Banner -->
    <section style="padding: 6rem clamp(1.5rem, 5vw, 4rem); background: var(--navy-800); border-top: 1px solid rgba(201, 168, 76, 0.1); border-bottom: 1px solid rgba(201, 168, 76, 0.1);">
      <div class="container">
        <div style="text-align: center; max-width: 600px; margin: 0 auto;" class="animate-fade-up">
          <span class="section-label" style="justify-content: center; display: flex;">Primul pas</span>
          <h2 class="section-title">Consultație gratuită <em>pentru cazul dvs.</em></h2>
          <p style="color: var(--slate-400); font-size: 1rem; line-height: 1.8; margin: 1.5rem 0 2.5rem;">
            Nu amânați. O consultație inițială vă poate clarifica situația juridică și vă poate ajuta să luați cele mai bune decizii.
          </p>
          <a href="/#contact" class="btn-primary">Contactați-mă astăzi</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  .servicii-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .servicii-hero-bg {
    position: absolute;
    inset: 0;
  }

  .servicii-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }

  .servicii-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 14, 26, 0.55) 0%,
      rgba(10, 14, 26, 0.75) 50%,
      rgba(10, 14, 26, 0.97) 100%
    );
  }

  .servicii-hero-content {
    position: relative;
    z-index: 2;
    padding-top: 10rem;
    padding-bottom: 5rem;
  }

  .services-detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    background: rgba(201, 168, 76, 0.06);
  }

  .service-detail-card {
    background: var(--navy-900);
    padding: 3rem 2.5rem;
    border-top: 3px solid transparent;
    transition: border-color 0.3s ease, background 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .service-detail-card:hover {
    border-top-color: var(--gold-400);
    background: var(--navy-800);
  }

  .service-detail-header {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    margin-bottom: 2rem;
  }

  .service-detail-icon {
    width: 56px;
    height: 56px;
    border: 1px solid rgba(201, 168, 76, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold-400);
    flex-shrink: 0;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .service-detail-card:hover .service-detail-icon {
    border-color: var(--gold-400);
    box-shadow: 0 0 20px var(--gold-glow);
  }

  .service-detail-title {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--cream-100);
    margin: 0.25rem 0 0.5rem;
  }

  .service-detail-short {
    font-size: 0.8rem;
    color: var(--gold-300);
    letter-spacing: 0.05em;
  }

  .service-detail-body {
    flex: 1;
  }

  .service-detail-body p {
    font-size: 0.9rem;
    color: var(--slate-400);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .service-detail-body p:last-child {
    margin-bottom: 0;
  }

  .service-detail-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold-400);
    margin-top: 2rem;
    transition: gap 0.3s ease;
  }

  .service-detail-cta:hover {
    gap: 0.75rem;
  }

  @media (max-width: 900px) {
    .services-detail-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
